{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkillsConfig",
  "type": "object",
  "required": ["skills"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "userInvocable": {
            "type": "boolean"
          },
          "triggers": {
            "type": "object",
            "properties": {
              "fileExtensions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "pathPatterns": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "keywords": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
