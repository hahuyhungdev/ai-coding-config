{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkillsConfig",
  "type": "object",
  "required": ["skills"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "minLength": 1,
            "maxLength": 64
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^skills/[a-z0-9-]+/SKILL\\.md$"
          },
          "userInvocable": {
            "type": "boolean"
          },
          "triggers": {
            "type": "object",
            "properties": {
              "fileExtensions": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "pathPatterns": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "keywords": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          },
          "dependencies": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
