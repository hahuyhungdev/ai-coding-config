#!/bin/bash

AGY_DIR="${AGY_DIR_OVERRIDE:-$HOME/.gemini/antigravity-cli}"
REAL_AGY="${REAL_AGY_OVERRIDE:-$HOME/.local/bin/agy-bin}"
MAX_RETRIES=2  # Up to 2 retries: 1 model-switch + 1 account-switch
ROLLOVER_PROGRESS_CONTENT=""
ROLLOVER_CONV_ID=""
RESUME_ARGS=()
AGY_SESSION_ID="${AGY_SESSION_ID_OVERRIDE:-$(date +%Y%m%d%H%M%S)-$$-$RANDOM}"
AGY_STATE_ROOT="${AGY_STATE_ROOT_OVERRIDE:-$AGY_DIR/session-state}"
AGY_WRAPPER_STATE_DIR="${AGY_WRAPPER_STATE_DIR_OVERRIDE:-$AGY_STATE_ROOT/$AGY_SESSION_ID}"
AGY_SESSION_TOKEN_FILE="${AGY_SESSION_TOKEN_FILE_OVERRIDE:-$AGY_WRAPPER_STATE_DIR/active-token.json}"
export AGY_WRAPPER_SESSION_ID
export AGY_WRAPPER_STATE_DIR
export AGY_SESSION_TOKEN_FILE

mkdir -p "$AGY_WRAPPER_STATE_DIR" 2>/dev/null || true
chmod 700 "$AGY_WRAPPER_STATE_DIR" 2>/dev/null || true

snapshot_active_token() {
    mkdir -p "$AGY_WRAPPER_STATE_DIR" 2>/dev/null || true
    if [ -f "$AGY_DIR/antigravity-oauth-token" ]; then
        cp "$AGY_DIR/antigravity-oauth-token" "$AGY_SESSION_TOKEN_FILE" 2>/dev/null || true
        chmod 600 "$AGY_SESSION_TOKEN_FILE" 2>/dev/null || true
    fi
}

consume_rollover_state() {
    ROLLOVER_PROGRESS_CONTENT="No progress summary found."
    ROLLOVER_CONV_ID=""

    local progress_file=""
    if [ -f ".agy_progress.md" ]; then
        progress_file=".agy_progress.md"
    elif [ -f "PROGRESS.md" ]; then
        progress_file="PROGRESS.md"
    fi

    if [ -n "$progress_file" ]; then
        ROLLOVER_PROGRESS_CONTENT=$(cat "$progress_file")
        if [ "$progress_file" = ".agy_progress.md" ]; then
            rm -f "$progress_file"
        fi
    fi

    rm -f "$AGY_WRAPPER_STATE_DIR/.compact_signal"

    if [ -f "$AGY_WRAPPER_STATE_DIR/.active_conv_id" ]; then
        ROLLOVER_CONV_ID=$(cat "$AGY_WRAPPER_STATE_DIR/.active_conv_id" | tr -d '\r\n[:space:]')
        rm -f "$AGY_WRAPPER_STATE_DIR/.active_conv_id"
    fi

    mkdir -p "$AGY_WRAPPER_STATE_DIR" 2>/dev/null || true
    printf '%s\n' "$ROLLOVER_PROGRESS_CONTENT" > "$AGY_WRAPPER_STATE_DIR/.last_rollover_summary.md" 2>/dev/null || true
}

prepare_idle_rollover_resume() {
    RESUME_ARGS=()
    if [ -n "$ROLLOVER_CONV_ID" ]; then
        RESUME_ARGS=("--conversation" "$ROLLOVER_CONV_ID")
    fi

    echo -e "\n\033[1;32m♻️ [AUTO-RESUMING SESSION (QUOTA ROLLOVER)]...\033[0m"
    echo "Rollover summary saved to: $AGY_WRAPPER_STATE_DIR/.last_rollover_summary.md"
    echo "No prompt was auto-submitted; the resumed session will wait for your next message."
    echo
}

set_model_arg() {
    local model="$1"
    shift
    MODEL_ARGS=()
    local skip_next=false

    for arg in "$@"; do
        if [ "$skip_next" = true ]; then
            skip_next=false
            continue
        fi

        if [ "$arg" = "--model" ]; then
            skip_next=true
            continue
        fi

        if [[ "$arg" == --model=* ]]; then
            continue
        fi

        MODEL_ARGS+=("$arg")
    done

    MODEL_ARGS+=("--model" "$model")
}

# Parse arguments to identify positional args, flags, and options
has_prompt_flag=false
has_help_flag=false
has_json_flag=false
positional_args=()
skip_next=false

for arg in "$@"; do
    if [ "$skip_next" = true ]; then
        skip_next=false
        continue
    fi
    case "$arg" in
        -p|--print|--prompt|-i|--prompt-interactive)
            has_prompt_flag=true
            ;;
        -h|--help)
            has_help_flag=true
            ;;
        --json)
            has_json_flag=true
            ;;
        --add-dir|--conversation|--log-file|--model|--print-timeout)
            skip_next=true
            ;;
        -*)
            # other flags
            ;;
        *)
            positional_args+=("$arg")
            ;;
    esac
done

subcmd="${positional_args[0]}"
subcmd2="${positional_args[1]}"

# Native agy-bin subcommands must bypass the account-management router.
native_command=false
if [ "$has_prompt_flag" = false ]; then
    case "$subcmd" in
        changelog|install|models|plugin|plugins|update)
            native_command=true
            ;;
        help)
            case "$subcmd2" in
                changelog|install|models|plugin|plugins|update|help)
                    native_command=true
                    ;;
            esac
            ;;
    esac
fi



# Management commands are handled by the Python CLI; everything else launches agy-bin.
if [[ "$has_prompt_flag" == false && "$native_command" == false && ( -n "$subcmd" || "$has_help_flag" == true || "$has_json_flag" == true ) ]]; then
    is_mgmt_cmd=false
    if [[ ( "$has_help_flag" == true || "$has_json_flag" == true ) && -z "$subcmd" ]]; then
        is_mgmt_cmd=true
    else
        case "$subcmd" in
            status|account|doctor|backup|restore|current|rename|info|show|list|ls|accounts|weekly|week|usage-week|weekly-usage|select|choose|use|add|add-current|add-current-account|import|save|help|guide|clean|cleanup|prune|compact|delete|remove|rm|remove-account|rm-account|delete-account|import-file|add-file|load|add-token|paste|new-token|rotate|config)
                is_mgmt_cmd=true
                ;;
        esac
    fi

    if [ "$is_mgmt_cmd" = true ]; then
        if [ -f "$AGY_DIR/agy-status.py" ]; then
            exec python3 "$AGY_DIR/agy-status.py" "$@"
        fi
    else
        # A bare unknown word (or typo) shouldn't launch agy-bin
        if [ -f "$AGY_DIR/agy-status.py" ]; then
            exec python3 "$AGY_DIR/agy-status.py" _suggest "$@"
        fi
    fi
fi

if [[ "$native_command" == true ]]; then
    if [ ! -f "$REAL_AGY" ]; then
        echo "❌ Error: Real agy binary not found at $REAL_AGY"
        exit 1
    fi
    exec "$REAL_AGY" "$@"
fi

# Proactive: auto-switch to ensure active account has quota before running
# Captures output — last line may be a suggested model if account was switched
SUGGESTED_MODEL=""
if [ -f "$AGY_DIR/agy-status.py" ]; then
    switch_output=$(python3 "$AGY_DIR/agy-status.py" auto-switch 2>&1)
    if [ -n "$switch_output" ]; then
        echo "$switch_output" | grep -v "^MODEL:"
    fi
    # If auto-switch printed a model suggestion (non-empty return), use it
    last_line=$(echo "$switch_output" | tail -1)
    if [[ "$last_line" == MODEL:* ]]; then
        SUGGESTED_MODEL="${last_line#MODEL:}"
    fi
fi

# Run agy-bin with retry-on-quota-error logic
if [ ! -f "$REAL_AGY" ]; then
    echo "❌ Error: Real agy binary not found at $REAL_AGY"
    exit 1
fi

# Detect if this is a print-mode (non-interactive) command
is_print_mode=false
for arg in "$@"; do
    if [ "$arg" = "-p" ]; then
        is_print_mode=true
        break
    fi
done

attempt=0
skip_post_check_once=false
while [ $attempt -le $MAX_RETRIES ]; do
    needs_check=false
    # Build args — inject --model if suggested by auto-switch or post-check
    if [ -n "$SUGGESTED_MODEL" ]; then
        set_model_arg "$SUGGESTED_MODEL" "$@"
        set -- "${MODEL_ARGS[@]}"
        SUGGESTED_MODEL=""  # Only inject once
    fi
    snapshot_active_token

    if [ "$is_print_mode" = true ]; then
        # Print mode: capture output to detect silent failures
        agy_output=$("$REAL_AGY" "$@" 2>&1)
        exit_code=$?
        if [ -n "$agy_output" ]; then
            echo "$agy_output"
        fi
    else
        # Interactive mode: run directly (no capture) with background log monitor
        MONITOR_PID=""
        if [ -f "$AGY_DIR/log_monitor.py" ]; then
            python3 "$AGY_DIR/log_monitor.py" "$$" &
            MONITOR_PID=$!
        fi

        "$REAL_AGY" "$@"
        exit_code=$?

        if [ -n "$MONITOR_PID" ]; then
            kill $MONITOR_PID 2>/dev/null
        fi
    fi

    # Check for reload/compaction signal from before_agent or after_agent
    if [ -f "$AGY_WRAPPER_STATE_DIR/.compact_signal" ]; then
        consume_rollover_state
        prepare_idle_rollover_resume
        set -- "${RESUME_ARGS[@]}"
        is_print_mode=false # Always reload into interactive mode for user confirmation
        skip_post_check_once=true
        attempt=0
        continue
    fi

    if [ "$skip_post_check_once" = true ]; then
        skip_post_check_once=false
        exit $exit_code
    fi

    # Fallback log-based error recovery
    if [ "$is_print_mode" = true ]; then
        if [ $exit_code -ne 0 ] || [ -z "$agy_output" ]; then
            needs_check=true
        fi
    else
        needs_check=true
    fi

    if [ "$needs_check" = true ] && [ -f "$AGY_DIR/agy-status.py" ]; then
        recovery_output=$(python3 "$AGY_DIR/agy-status.py" post-check 2>&1)
        recovery_code=$?
        if [ -n "$recovery_output" ]; then
            echo "$recovery_output" | grep -v "^SWITCH_ACCOUNT$"
        fi
        if [ $recovery_code -eq 0 ] && echo "$recovery_output" | grep -q "^SWITCH_ACCOUNT$"; then
            attempt=$((attempt + 1))

            if [ "$is_print_mode" = false ]; then
                consume_rollover_state
                prepare_idle_rollover_resume
                set -- "${RESUME_ARGS[@]}"
                is_print_mode=false
                skip_post_check_once=true
            fi

            continue
        fi
    fi

    exit $exit_code
done

exit 1
