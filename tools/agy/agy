#!/bin/bash

AGY_DIR="${AGY_DIR_OVERRIDE:-$HOME/.gemini/antigravity-cli}"
REAL_AGY="$HOME/.local/bin/agy-bin"
MAX_RETRIES=2  # Up to 2 retries: 1 model-switch + 1 account-switch

set_model_arg() {
    local model="$1"
    shift
    MODEL_ARGS=()
    local skip_next=false

    for arg in "$@"; do
        if [ "$skip_next" = true ]; then
            skip_next=false
            continue
        fi

        if [ "$arg" = "--model" ]; then
            skip_next=true
            continue
        fi

        if [[ "$arg" == --model=* ]]; then
            continue
        fi

        MODEL_ARGS+=("$arg")
    done

    MODEL_ARGS+=("--model" "$model")
}

# Parse arguments to identify positional args, flags, and options
has_prompt_flag=false
has_help_flag=false
has_json_flag=false
positional_args=()
skip_next=false

for arg in "$@"; do
    if [ "$skip_next" = true ]; then
        skip_next=false
        continue
    fi
    case "$arg" in
        -p|--print|--prompt|-i|--prompt-interactive)
            has_prompt_flag=true
            ;;
        -h|--help)
            has_help_flag=true
            ;;
        --json)
            has_json_flag=true
            ;;
        --add-dir|--conversation|--log-file|--model|--print-timeout)
            skip_next=true
            ;;
        -*)
            # other flags
            ;;
        *)
            positional_args+=("$arg")
            ;;
    esac
done

subcmd="${positional_args[0]}"
subcmd2="${positional_args[1]}"

# Native agy-bin subcommands must bypass the account-management router.
native_command=false
if [ "$has_prompt_flag" = false ]; then
    case "$subcmd" in
        changelog|install|models|plugin|plugins|update)
            native_command=true
            ;;
        help)
            case "$subcmd2" in
                changelog|install|models|plugin|plugins|update|help)
                    native_command=true
                    ;;
            esac
            ;;
    esac
fi

# 'auto' mode: spawn rotate daemon in background, then launch agy-bin as normal
if [[ "$subcmd" == "auto" || "$subcmd" == "daemon" ]]; then
    DAEMON_PID_FILE="$AGY_DIR/auto_rotate_daemon.pid"
    DAEMON_LOG="$AGY_DIR/auto_daemon.log"
    DAEMON_OWNER=false

    # Check if a daemon is already running via PID file
    if [ -f "$DAEMON_PID_FILE" ]; then
        EXISTING_PID=$(cat "$DAEMON_PID_FILE" 2>/dev/null)
        if [ -n "$EXISTING_PID" ] && kill -0 "$EXISTING_PID" 2>/dev/null; then
            echo "ℹ️ Auto-rotate daemon already running (PID: $EXISTING_PID). Reusing existing daemon."
            echo "   Log: $DAEMON_LOG"
            # Don't kill the existing daemon on exit — we didn't spawn it
            shift
            subcmd=""
        else
            # Stale PID file — daemon is dead, clean up and spawn new
            rm -f "$DAEMON_PID_FILE" 2>/dev/null
        fi
    fi

    # Spawn a new daemon only if we didn't reuse an existing one
    if [ "$subcmd" = "auto" ] || [ "$subcmd" = "daemon" ]; then
        setsid python3 "$AGY_DIR/auto_rotate_daemon.py" > "$DAEMON_LOG" 2>&1 &
        DAEMON_PID=$!
        disown $DAEMON_PID 2>/dev/null
        DAEMON_OWNER=true
        # Auto-kill daemon when THIS CLI session exits (only if we spawned it)
        trap "kill $DAEMON_PID 2>/dev/null; rm -f '$DAEMON_PID_FILE' 2>/dev/null; echo '🛑 Auto-rotate daemon stopped.'" EXIT
        echo "🚀 Auto-rotate daemon started (PID: $DAEMON_PID). Checking every 5m in background."
        echo "   Log: $DAEMON_LOG"
        echo "   Daemon will auto-stop when you exit the CLI."
        # Remove 'auto'/'daemon' from args so agy-bin launches clean
        shift
        subcmd=""
    fi
fi

# Management commands are handled by the Python CLI; everything else launches agy-bin.
if [[ "$has_prompt_flag" == false && "$native_command" == false && ( -n "$subcmd" || "$has_help_flag" == true || "$has_json_flag" == true ) ]]; then
    is_mgmt_cmd=false
    if [[ ( "$has_help_flag" == true || "$has_json_flag" == true ) && -z "$subcmd" ]]; then
        is_mgmt_cmd=true
    else
        case "$subcmd" in
            status|account|doctor|backup|restore|current|rename|info|show|list|ls|accounts|weekly|week|usage-week|weekly-usage|select|choose|use|add|add-current|add-current-account|import|save|help|guide|clean|cleanup|prune|compact|delete|remove|rm|remove-account|rm-account|delete-account|import-file|add-file|load|add-token|paste|new-token|rotate|daemon)
                is_mgmt_cmd=true
                ;;
        esac
    fi

    if [ "$is_mgmt_cmd" = true ]; then
        if [ -f "$AGY_DIR/agy-status.py" ]; then
            exec python3 "$AGY_DIR/agy-status.py" "$@"
        fi
    else
        # A bare unknown word (or typo) shouldn't launch agy-bin
        if [ -f "$AGY_DIR/agy-status.py" ]; then
            exec python3 "$AGY_DIR/agy-status.py" _suggest "$@"
        fi
    fi
fi

if [[ "$native_command" == true ]]; then
    if [ ! -f "$REAL_AGY" ]; then
        echo "❌ Error: Real agy binary not found at $REAL_AGY"
        exit 1
    fi
    exec "$REAL_AGY" "$@"
fi

# Proactive: auto-switch to ensure active account has quota before running
# Captures output — last line may be a suggested model if account was switched
SUGGESTED_MODEL=""
if [ -f "$AGY_DIR/agy-status.py" ]; then
    switch_output=$(python3 "$AGY_DIR/agy-status.py" auto-switch 2>&1)
    if [ -n "$switch_output" ]; then
        echo "$switch_output" | grep -v "^MODEL:"
    fi
    # If auto-switch printed a model suggestion (non-empty return), use it
    last_line=$(echo "$switch_output" | tail -1)
    if [[ "$last_line" == MODEL:* ]]; then
        SUGGESTED_MODEL="${last_line#MODEL:}"
    fi
fi

# Run agy-bin with retry-on-quota-error logic
if [ ! -f "$REAL_AGY" ]; then
    echo "❌ Error: Real agy binary not found at $REAL_AGY"
    exit 1
fi

# Detect if this is a print-mode (non-interactive) command
is_print_mode=false
for arg in "$@"; do
    if [ "$arg" = "-p" ]; then
        is_print_mode=true
        break
    fi
done

attempt=0
while [ $attempt -le $MAX_RETRIES ]; do
    needs_check=false
    # Build args — inject --model if suggested by auto-switch or post-check
    if [ -n "$SUGGESTED_MODEL" ]; then
        set_model_arg "$SUGGESTED_MODEL" "$@"
        set -- "${MODEL_ARGS[@]}"
        SUGGESTED_MODEL=""  # Only inject once
    fi

    if [ "$is_print_mode" = true ]; then
        # Print mode: capture output to detect silent failures
        agy_output=$("$REAL_AGY" "$@" 2>&1)
        exit_code=$?
        if [ -n "$agy_output" ]; then
            echo "$agy_output"
        fi
        # Empty output + exit 0 = silent quota failure
        if [ $exit_code -ne 0 ] || [ -z "$agy_output" ]; then
            needs_check=true
        fi
    else
        # Interactive mode: run directly (no capture)
        "$REAL_AGY" "$@"
        exit_code=$?
        if [ -f "$HOME/.gemini/antigravity-cli/.compact_signal" ]; then
            PROGRESS_FILE=""
            if [ -f ".agy_progress.md" ]; then
                PROGRESS_FILE=".agy_progress.md"
            elif [ -f "PROGRESS.md" ]; then
                PROGRESS_FILE="PROGRESS.md"
            fi

            if [ -n "$PROGRESS_FILE" ]; then
                PROGRESS_CONTENT=$(cat "$PROGRESS_FILE")
                rm -f "$PROGRESS_FILE"
            else
                PROGRESS_CONTENT="No progress summary found."
            fi

            rm -f "$HOME/.gemini/antigravity-cli/.compact_signal"
            echo -e "\n\033[1;32m♻️ [AUTO-RESUMING COMPACTED SESSION]...\033[0m\n"
            AUTO_PROMPT=$(echo -e "<compaction_rollover>\n<instructions>\n- You are resuming a compacted session. Read the progress summary below to restore your context.\n- IMPORTANT: Do NOT execute any pending tasks or run commands automatically. Present the summary, suggest the next step, and wait for user confirmation.\n- Use Graphify commands (e.g. rtk graphify) on-demand if you need to explore code symbols or structure.\n</instructions>\n\n<progress_summary>\n$PROGRESS_CONTENT\n</progress_summary>\n</compaction_rollover>")
            set -- "-i" "$AUTO_PROMPT"
            attempt=0
            continue
        fi
        if [ $exit_code -ne 0 ]; then
            needs_check=true
        fi
    fi

    if [ "$needs_check" = true ] && [ -f "$AGY_DIR/agy-status.py" ]; then
        recovery_output=$(python3 "$AGY_DIR/agy-status.py" post-check 2>&1)
        recovery_code=$?
        if [ -n "$recovery_output" ]; then
            echo "$recovery_output" | grep -v "^SWITCH_ACCOUNT$"
        fi
        if [ $recovery_code -eq 0 ] && echo "$recovery_output" | grep -q "^SWITCH_ACCOUNT$"; then
            attempt=$((attempt + 1))
            continue
        fi
    fi

    exit $exit_code
done

exit 1
