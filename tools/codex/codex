#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ACCOUNT_HELPER="$SCRIPT_DIR/../codex-account/codex-account.py"

if [ ! -f "$ACCOUNT_HELPER" ]; then
    ACCOUNT_HELPER="$HOME/projects/personals/ai-coding-config/tools/codex-account/codex-account.py"
fi

REAL_CODEX="${CODEX_REAL_BIN:-$HOME/.local/bin/codex-bin}"

run_account_helper() {
    if [ ! -f "$ACCOUNT_HELPER" ]; then
        echo "Error: codex-account helper not found at $ACCOUNT_HELPER" >&2
        exit 1
    fi
    exec env CODEX_ACCOUNT_PROG="${CODEX_ACCOUNT_PROG:-codex}" python3 "$ACCOUNT_HELPER" "$@"
}

run_real_codex() {
    if [ ! -x "$REAL_CODEX" ]; then
        echo "Error: real codex binary not found or not executable at $REAL_CODEX" >&2
        echo "Set CODEX_REAL_BIN to the original Codex executable." >&2
        exit 1
    fi
    exec "$REAL_CODEX" "$@"
}

case "${1:-}" in
    account)
        shift
        export CODEX_ACCOUNT_PROG="codex account"
        if [ "$#" -eq 0 ]; then
            run_account_helper list
        fi
        run_account_helper "$@"
        ;;
    accounts)
        shift
        export CODEX_ACCOUNT_PROG="codex account"
        if [ "$#" -eq 0 ]; then
            run_account_helper list
        fi
        run_account_helper "$@"
        ;;
    list|ls)
        shift
        run_account_helper list "$@"
        ;;
    guide)
        shift
        run_account_helper guide "$@"
        ;;
    check)
        shift
        target=""
        if [ "$#" -gt 0 ] && [ "${1#-}" = "$1" ]; then
            target="$1"
            shift
        fi
        if [ -n "$target" ]; then
            run_account_helper status --refresh --account "$target" --timeout "${CODEX_ACCOUNT_CHECK_TIMEOUT:-30}" "$@"
        fi
        run_account_helper status --refresh --timeout "${CODEX_ACCOUNT_CHECK_TIMEOUT:-30}" "$@"
        ;;
    status)
        shift
        run_account_helper status --timeout "${CODEX_ACCOUNT_CHECK_TIMEOUT:-30}" "$@"
        ;;
    rotate)
        shift
        run_account_helper rotate "$@"
        ;;
    current)
        shift
        run_account_helper current "$@"
        ;;
    use)
        shift
        run_account_helper use "$@"
        ;;
    switch)
        shift
        run_account_helper use "$@"
        ;;
    add)
        shift
        run_account_helper add "$@"
        ;;
    token)
        shift
        run_account_helper add-token "$@"
        ;;
    add-current|add-current-account)
        shift
        run_account_helper add "$@"
        ;;
    add-token|add-refresh-token)
        shift
        run_account_helper add-token "$@"
        ;;
    login-temp|temp-login)
        shift
        run_account_helper login-temp "$@"
        ;;
    relabel-accounts)
        shift
        run_account_helper relabel "$@"
        ;;
    help)
        case "${2:-}" in
            account|accounts)
                run_account_helper --help
                ;;
        esac
        ;;
esac

run_real_codex "$@"
