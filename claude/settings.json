{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ECC_GATEGUARD": "off",
    "MAX_THINKING_TOKENS": "20000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "12000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "60",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "ECC_SESSION_START_MAX_CHARS": "4000",
    "ECC_CONTEXT_MONITOR_COST_WARNINGS": "off"
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(npm run *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(python *)",
      "Bash(pytest *)",
      "Bash(pip install *)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*secret*)",
      "Read(**/*token*)",
      "Read(**/*credential*)",
      "Read(**/*private*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf .)",
      "Bash(sudo *)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ],
    "defaultMode": "bypassPermissions"
  }
}
